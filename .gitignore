# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
# Frontend env files (keep .env.example tracked)
frontend/.env.development
frontend/.env.local

# .VS / Visual Studio local state (open files, window layout — machine-specific, not shareable)
.vs/

# .NET build output
**/bin/
**/obj/

# Node
frontend/node_modules/
frontend/dist/
*.v2
*.vsidx
*.suo
*.user
*.db
