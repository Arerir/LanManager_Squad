# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# ============================================================
# .NET / ASP.NET Core
# ============================================================

# Build output
**/bin/
**/obj/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/

# User-specific / local overrides (may contain secrets or machine paths)
*.user
appsettings.Local.json
appsettings.local.json

# .NET user secrets (stored in AppData normally, but guard the file if present)
secrets.json

# Publish output
**/publish/

# Test results
**/TestResults/
**/*.trx
**/*.coverage
**/*.coveragexml

# Coverage reports
**/Coverage/

# Crash dumps
*.dmp

# ============================================================
# Visual Studio / Rider IDE
# ============================================================

# VS local state (open documents, window layout — machine-specific)
.vs/
*.suo
*.vsidx
*.v2

# Rider
.idea/
*.sln.iml

# ============================================================
# MAUI / Mobile
# ============================================================

# Android signing keys — NEVER commit these
*.keystore
*.jks

# iOS certificates / provisioning
*.p12
*.pfx
*.cer
*.mobileprovision

# Firebase config files (contain project credentials)
google-services.json
GoogleService-Info.plist

# ============================================================
# React / Node / Vite
# ============================================================

frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.development
frontend/.env.production
frontend/.env.*.local

# ============================================================
# General
# ============================================================

# OS metadata
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Logs
*.log
logs/

# Temp files
*.tmp
*.temp
*.swp
*.bak

# SQLite databases (local dev data)
*.db
*.db-shm
*.db-wal

# Certificates / secrets (catch-all)
*.pem
*.key
