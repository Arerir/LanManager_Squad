<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LanManager.Maui.ViewModels"
             xmlns:services="clr-namespace:LanManager.Maui.Services"
             x:Class="LanManager.Maui.Views.CheckInPage"
             x:DataType="viewmodels:CheckInViewModel"
             Title="Check-In Operator">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Event header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <Label Grid.Column="0"
                   Text="{Binding EventName}"
                   FontSize="22"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
            
            <Label Grid.Column="1"
                   FontSize="18"
                   VerticalOptions="Center">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Checked In: " />
                        <Span Text="{Binding CheckedInCount}" FontAttributes="Bold" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </Grid>

        <!-- Status message -->
        <Border Grid.Row="1"
               BackgroundColor="{Binding StatusColor}"
               IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
               Padding="10"
               Margin="0,0,0,10"
               StrokeShape="RoundRectangle 5">
            <Label Text="{Binding StatusMessage}"
                   TextColor="White"
                   FontSize="16"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
        </Border>

        <!-- Search bar -->
        <SearchBar Grid.Row="2"
                   Placeholder="Search by name or email..."
                   Text="{Binding SearchText}"
                   Margin="0,0,0,10" />

        <!-- Mode toggle and attendance button -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Text="{Binding IsCheckOutMode, Converter={StaticResource CheckModeTextConverter}}"
                    Command="{Binding ToggleCheckOutModeCommand}"
                    BackgroundColor="{Binding IsCheckOutMode, Converter={StaticResource CheckModeColorConverter}}"
                    Margin="0,0,5,0" />

            <Button Grid.Column="1"
                    Text="Attendance"
                    Command="{Binding GoToAttendanceCommand}"
                    Margin="5,0,0,0" />
        </Grid>

        <!-- User list -->
        <CollectionView Grid.Row="4"
                       ItemsSource="{Binding FilteredUsers}"
                       SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="services:UserDto">
                    <Border Padding="10"
                           Margin="0,5"
                           StrokeShape="RoundRectangle 5"
                           BackgroundColor="{StaticResource Gray100}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CheckInViewModel}}, Path=CheckInUserCommand}"
                                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <StackLayout Grid.Column="0">
                                <Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Email}"
                                       FontSize="14"
                                       TextColor="Gray" />
                            </StackLayout>

                            <Label Grid.Column="1"
                                   Text="→"
                                   FontSize="24"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading overlay -->
        <ActivityIndicator Grid.RowSpan="5"
                          IsRunning="{Binding IsLoading}"
                          IsVisible="{Binding IsLoading}"
                          Color="{StaticResource Primary}"
                          VerticalOptions="Center"
                          HorizontalOptions="Center" />
    </Grid>

</ContentPage>
