<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LanManager.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LanManager.Maui.Views"
    Title="LanManager">

    <ShellContent
        Title="Event Selector"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Check-In"
        ContentTemplate="{DataTemplate views:CheckInPage}"
        Route="CheckInPage" />

    <ShellContent
        Title="Attendance"
        ContentTemplate="{DataTemplate views:AttendancePage}"
        Route="AttendancePage" />

    <ShellContent
        x:Name="ScannerContent"
        Title="QR Scanner"
        ContentTemplate="{DataTemplate views:DoorScanPage}"
        Route="DoorScanPage"
        IsVisible="False" />

</Shell>
