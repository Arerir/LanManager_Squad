<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:LanManager.Maui.Crew.Views"
       x:Class="LanManager.Maui.Crew.CrewAppShell"
       Title="LanManager Crew">

    <ShellContent
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage"
        Shell.NavBarIsVisible="False" />

    <ShellContent
        Title="Event Selector"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

    <TabBar>
        <Tab Title="Check In" Icon="icon_checkin.svg">
            <ShellContent
                ContentTemplate="{DataTemplate views:CheckInPage}"
                Route="CheckInPage" />
        </Tab>
        <Tab Title="Attendance" Icon="icon_attendance.svg">
            <ShellContent
                ContentTemplate="{DataTemplate views:AttendancePage}"
                Route="AttendancePage" />
        </Tab>
    </TabBar>
</Shell>
